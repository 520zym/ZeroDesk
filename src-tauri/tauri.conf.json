{
  "$schema": "https://raw.githubusercontent.com/nicerloop/tauri-schema/refs/heads/main/src/tauri.conf.schema.json",
  "productName": "ZeroDesk",
  "version": "0.0.2",
  "identifier": "com.zerodesk.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1520",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
